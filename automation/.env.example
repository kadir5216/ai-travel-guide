# Strapi Base API URL
STRAPI_URL=http://localhost:1337

# Strapi API Token (Settings > API Tokens > Create new API Token)
# Token Type: Custom | Permissions: Cities (find, findOne, create, update), Places (find, findOne, create, update), Upload (upload)
STRAPI_API_TOKEN=your_strapi_api_token_here

# Pollinations API Key (Required for current Pollinations image generation API)
# Get your key from: https://enter.pollinations.ai
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Groq API Key (Primary AI text generation service for place/city descriptions)
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# Pollinations text model used as fallback for AI-generated place/city descriptions
POLLINATIONS_TEXT_MODEL=nova-fast

# HuggingFace API Key (Optional - Secondary AI image generation fallback)
# Get your key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
