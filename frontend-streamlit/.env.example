# Strapi Base API URL
# Local development:
STRAPI_URL=http://localhost:1337

# Render production (uncomment and set your Render Strapi URL):
# STRAPI_URL=https://ai-travel-guide-strapi.onrender.com

# Optional but recommended if Strapi public read permissions are disabled:
# STRAPI_API_TOKEN=your_read_only_strapi_api_token_here

# Render Blueprint sets this automatically for private service-to-service traffic:
# STRAPI_INTERNAL_HOSTPORT=ai-travel-guide-strapi:10000
