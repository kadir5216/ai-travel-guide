# Server
HOST=0.0.0.0
PORT=1337

# Internationalization
STRAPI_PLUGIN_I18N_INIT_LOCALE_CODE=tr

# Secrets (Render will auto-generate these via render.yaml)
APP_KEYS=toBeGeneratedOnRender1==,toBeGeneratedOnRender2==
API_TOKEN_SALT=toBeGeneratedOnRender==
ADMIN_JWT_SECRET=toBeGeneratedOnRender==
TRANSFER_TOKEN_SALT=toBeGeneratedOnRender==
JWT_SECRET=toBeGeneratedOnRender==

# Database (Default: SQLite for local development)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# For Render Production: set DATABASE_CLIENT=postgres and DATABASE_URL via env vars

# Upload Provider (local for dev, cloudinary for production)
UPLOAD_PROVIDER=local

# Cloudinary (Required for Render production deployment)
# CLOUDINARY_NAME=your_cloud_name
# CLOUDINARY_KEY=your_api_key
# CLOUDINARY_SECRET=your_api_secret
